# ============================================
# AEROCHECK - Configuration exemple
# ============================================

# Backend
PORT=3300
API_PORT=3300
API_BASE_URL=http://127.0.0.1:3300
PING_MESSAGE="AEROCHECK API ready"

# Frontend (hébergé sur un autre serveur)
# Utiliser index.php comme proxy API pour contourner CORS/http
VITE_API_URL=http://82.165.150.150:3300/index.php

# Frontend local (développement) - décommenter pour usage local
# FRONTEND_PORT=3010
# FRONTEND_URL=http://127.0.0.1:3010
# VITE_API_URL=http://localhost:3300/api

# SQLite
DATABASE_URL="file:./backend/prisma/dev.db"

# Secrets placeholders
JWT_SECRET=change-me
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=change-me

# Deployment
SERVER_IP=your.server.ip
SERVER_USER=root
SERVER_PASS=change-me
DEST_DIR=/var/www/AEROCHECK
DOMAIN=example.com
PM2_NAME=aerocheck-backend
