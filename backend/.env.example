# ============================================
# AEROCHECK Backend - Configuration exemple
# ============================================

# Backend (mode backend-only - pas de frontend local)
PORT=3300
API_PORT=3300
API_BASE_URL=http://0.0.0.0:3300
PING_MESSAGE="AEROCHECK API ready"

# CORS - Autoriser toutes les origines (frontend hébergé ailleurs)
# En production, remplacez par le domaine exact du frontend
CORS_ORIGINS=*

# SQLite
DATABASE_URL="file:./prisma/dev.db"

# Sécurité
JWT_SECRET=change-me-en-production

# Email (optionnel)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=change-me
