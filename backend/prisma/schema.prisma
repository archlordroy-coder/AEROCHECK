generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  password       String
  role           String       @default("AGENT")
  firstName      String
  lastName       String
  phone          String?
  paysId         String?      // Pour DNA et Admin: pays d'affectation
  pays           Pays?        @relation(fields: [paysId], references: [id])
  aeroportId     String?      // Aéroport d'affectation
  aeroport       Aeroport?    @relation(fields: [aeroportId], references: [id])
  matricule      String?      @unique  // Pour QIP, DLAA, DNA
  dateNomination DateTime?    // Date de nomination
  isActive       Boolean      @default(true)  // Pour verrouiller comptes
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  agent          Agent?
  validations    Validation[]
}

model Agent {
  id               String      @id @default(cuid())
  userId           String      @unique
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  matricule        String      @unique
  dateNaissance    DateTime
  lieuNaissance    String
  nationaliteId    String
  nationalite      Nationalite @relation(fields: [nationaliteId], references: [id])
  adresse          String
  fonction         String
  employeurId      String
  employeur        Employeur   @relation(fields: [employeurId], references: [id])
  paysId           String
  pays             Pays        @relation(fields: [paysId], references: [id])
  aeroportId       String
  aeroport         Aeroport    @relation(fields: [aeroportId], references: [id])
  zoneAcces        String      @default("[]")
  status           String      @default("EN_ATTENTE")
  sexe             String?     // M or F
  qualifications   String?     // JSON array of qualifications
  whatsapp         String?     // WhatsApp number
  photoUrl         String?     // Profile photo URL
  emailVerified    Boolean     @default(false)
  documents        Document[]
  licenses         License[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model Document {
  id             String       @id @default(cuid())
  agentId        String
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  type           String
  fileName       String
  filePath       String
  status         String       @default("EN_ATTENTE")
  expiresAt      DateTime?    // Date d'expiration pour notifications
  archived       Boolean      @default(false)  // Archivage
  archivedAt     DateTime?
  validations    Validation[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Validation {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  validatorId String
  validator   User     @relation(fields: [validatorId], references: [id])
  status      String   // VALIDE, REJETE
  niveau      String   // QIP, DLAA
  comment     String?
  createdAt   DateTime @default(now())
}

model License {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  numero         String   @unique
  dateEmission   DateTime
  dateExpiration DateTime
  status         String   @default("ACTIVE")
  qrCode         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // EXPIRATION_30J, EXPIRATION_15J, EXPIRATION_7J, VALIDATION, REJET
  title       String
  message     String
  read        Boolean  @default(false)
  data        String?  // JSON avec infos additionnelles
  createdAt   DateTime @default(now())
}

model DocumentTypeConfig {
  id                String   @id @default(cuid())
  type              String   @unique  // CARTE_IDENTITE, PERMIS_CONDUITE, etc.
  validityDuration  Int      // Durée de validité en jours
  isRequired        Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Table des nationalités
model Nationalite {
  id        String   @id @default(cuid())
  code      String   @unique  // ISO 3166-1 alpha-3 (SEN, CIV, etc.)
  nom       String   @unique
  agents    Agent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Table des employeurs
model Employeur {
  id        String   @id @default(cuid())
  nom       String   @unique
  agents    Agent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Table des pays africains
model Pays {
  id        String     @id @default(cuid())
  code      String     @unique  // ISO 3166-1 alpha-2
  nom       String     @unique
  nomFr     String     // Nom en français
  aeroports Aeroport[]
  agents    Agent[]
  users     User[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Table des aéroports africains
model Aeroport {
  id          String   @id @default(cuid())
  code        String   @unique  // Code IATA (DKR, ABJ, etc.)
  nom         String
  ville       String
  paysId      String
  pays        Pays     @relation(fields: [paysId], references: [id])
  agents      Agent[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

