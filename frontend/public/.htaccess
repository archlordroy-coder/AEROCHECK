# AEROCHECK - Configuration Apache pour SPA React + API Proxy

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Gérer les requêtes API - rediriger vers api/index.php
    RewriteRule ^api/(.*)$ api/index.php [L]

    # Pour les fichiers et dossiers qui existent, les servir directement
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Tout le reste vers index.html (SPA React)
    RewriteRule ^ index.html [L]
</IfModule>
