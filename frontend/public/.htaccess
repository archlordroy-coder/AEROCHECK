Options +FollowSymLinks
RewriteEngine On
RewriteBase /

# Pass Authorization header to PHP
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Redirect /api requests to index.php
# On utilise QSA pour garder les paramètres de requête et L pour arrêter là si ça matche
RewriteRule ^api/(.*)$ index.php/api/$1 [L,QSA]

# Standard SPA support (redirect non-files to index.html)
# On vérifie que le fichier ou dossier n'existe pas physiquement
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# On ignore index.php et tout autre fichier .php pour laisser le serveur les exécuter
RewriteCond %{REQUEST_URI} !\.php$
# On redirige vers index.html pour le routing React
RewriteRule . index.html [L]
