{
  "name": "aerocheck",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Plateforme de gestion des licences aeroportuaires ASECNA",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" --names \"BACKEND,FRONTEND\" --prefix-colors \"cyan,green\"",
    "dev:backend": "cd backend && npx tsx src/index.ts",
    "dev:frontend": "cd frontend && npx vite",
    "push:verify": "bash ./push-verify.sh",
    "test": "cd frontend && npm run test",
    "build": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "build:all": "npm run build:backend && npm run build",
    "start": "cd backend && npm start",
    "setup": "cd backend && npm install && cd ../frontend && npm install && cd ../backend && npm run db:init",
    "db:init": "cd backend && npm run db:init"
  },
  "dependencies": {},
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
