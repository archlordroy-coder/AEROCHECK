# ============================================
# AEROCHECK - Configuration Vercel
# ============================================
# Copie ces variables dans Vercel :
# Project Settings > Environment Variables

# --------------------------------------------
# BASE
# --------------------------------------------
NODE_ENV=production
VITE_API_URL=/api

# --------------------------------------------
# DATABASE
# --------------------------------------------
# Remplace par ton URL PostgreSQL (ex: Supabase, Neon, Railway)
DATABASE_URL=postgresql://username:password@host:5432/aerocheck?schema=public

# --------------------------------------------
# AUTHENTICATION
# --------------------------------------------
# Génère une clé forte : openssl rand -base64 32
JWT_SECRET=changez-moi-par-une-cle-forte-de-32-caracteres-plus

# --------------------------------------------
# API CONFIG
# --------------------------------------------
API_PORT=3000
API_BASE_URL=https://votre-projet.vercel.app/api
FRONTEND_URL=https://votre-projet.vercel.app
PING_MESSAGE=AEROCHECK API ready

# --------------------------------------------
# EMAIL / SMTP (Notifications)
# --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-app
SMTP_FROM=AEROCHECK <notifications@aerocheck.com>

# --------------------------------------------
# OPTIONAL: CLOUD STORAGE (pour fichiers documents)
# --------------------------------------------
# Si tu veux stocker les documents sur S3, GCS, etc.
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=xxx
# AWS_SECRET_ACCESS_KEY=xxx
# S3_BUCKET_NAME=aerocheck-documents
# S3_REGION=eu-west-1

# --------------------------------------------
# OPTIONAL: REDIS (pour sessions/cache)
# --------------------------------------------
# REDIS_URL=redis://username:password@host:6379

# --------------------------------------------
# OPTIONAL: MONITORING
# --------------------------------------------
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
